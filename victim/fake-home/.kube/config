apiVersion: v1
kind: Config
clusters:
- cluster:
    server: https://k3s:6443
    insecure-skip-tls-verify: true
  name: demo-cluster
contexts:
- context:
    cluster: demo-cluster
    user: admin
  name: demo
current-context: demo
users:
- name: admin
  user:
    token: PLACEHOLDER_REPLACED_AT_RUNTIME
